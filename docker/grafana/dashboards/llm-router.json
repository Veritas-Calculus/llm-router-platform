        },
        "overrides": []
      }
    },
    {
      "title": "Request Rate by Path (Top 10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(llm_router_http_requests_total[5m])) by (path))",
