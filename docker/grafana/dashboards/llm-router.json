      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_router_http_response_size_bytes_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_router_http_response_size_bytes_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
