{
    "annotations": {
        "list": []
    },
    "description": "Comprehensive monitoring for the LLM Router Platform — request throughput, latency percentiles, token economics, provider health, security events, and infrastructure metrics.",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "links": [],
    "panels": [
        {
            "title": "📊 Traffic Overview",
            "type": "row",
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
        },
        {
            "title": "Request Rate (req/s)",
            "type": "timeseries",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(rate(llm_router_http_requests_total{job=\"llm-router\"}[5m])) by (method, path)",
                    "legendFormat": "{{method}} {{path}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": { "fillOpacity": 15, "gradientMode": "scheme" }
                }
            },
            "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 }
        },
        {
            "title": "Error Rate (%)",
            "type": "timeseries",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(rate(llm_router_http_requests_total{job=\"llm-router\",status=~\"5..\"}[5m])) / sum(rate(llm_router_http_requests_total{job=\"llm-router\"}[5m])) * 100",
                    "legendFormat": "Error %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 1 },
                            { "color": "red", "value": 5 }
                        ]
                    },
                    "custom": { "fillOpacity": 10 }
                }
            },
            "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 }
        },
        {
            "title": "Requests In-Flight",
            "type": "gauge",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "llm_router_http_requests_in_flight{job=\"llm-router\"}",
                    "legendFormat": "In-Flight"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 50 },
                            { "color": "red", "value": 100 }
                        ]
                    },
                    "max": 200
                }
            },
            "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }
        },
        {
            "title": "Active Providers",
            "type": "stat",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(llm_router_provider_active)",
                    "legendFormat": "Active"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "steps": [
                            { "color": "red", "value": null },
                            { "color": "green", "value": 1 }
                        ]
                    }
                }
            },
            "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }
        },
        {
            "title": "Healthy API Keys",
            "type": "stat",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(llm_router_apikey_healthy)",
                    "legendFormat": "Healthy Keys"
                }
            ],
            "gridPos": { "h": 4, "w": 4, "x": 16, "y": 5 }
        },
        {
            "title": "Avg Response Size",
            "type": "stat",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(llm_router_http_response_size_bytes_bucket{job=\"llm-router\"}[5m])) by (le))",
                    "legendFormat": "P50"
                }
            ],
            "fieldConfig": {
                "defaults": { "unit": "decbytes" }
            },
            "gridPos": { "h": 4, "w": 4, "x": 20, "y": 5 }
        },
        {
            "title": "⏱️ Latency",
            "type": "row",
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
        },
        {
            "title": "Request Latency Percentiles",
            "type": "timeseries",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(llm_router_http_request_duration_seconds_bucket{job=\"llm-router\"}[5m])) by (le))",
                    "legendFormat": "P50"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(llm_router_http_request_duration_seconds_bucket{job=\"llm-router\"}[5m])) by (le))",
                    "legendFormat": "P95"
                },
                {
                    "expr": "histogram_quantile(0.99, sum(rate(llm_router_http_request_duration_seconds_bucket{job=\"llm-router\"}[5m])) by (le))",
                    "legendFormat": "P99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": { "fillOpacity": 10, "gradientMode": "scheme" }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 }
        },
        {
            "title": "Provider Latency Distribution",
            "type": "heatmap",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(rate(llm_router_provider_latency_seconds_bucket{job=\"llm-router\"}[5m])) by (le, provider)",
                    "legendFormat": "{{provider}}"
                }
            ],
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 }
        },
        {
            "title": "💰 Token Economics",
            "type": "row",
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
        },
        {
            "title": "Token Usage by Provider",
            "type": "timeseries",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(rate(llm_router_tokens_consumed_total{job=\"llm-router\"}[5m])) by (provider, direction)",
                    "legendFormat": "{{provider}} {{direction}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 }
        },
        {
            "title": "Cost per Hour ($)",
            "type": "timeseries",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "sum(increase(llm_router_cost_usd_total{job=\"llm-router\"}[1h])) by (provider)",
                    "legendFormat": "{{provider}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "currencyUSD",
                    "custom": { "fillOpacity": 15, "gradientMode": "scheme" }
                }
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 }
        },
        {
            "title": "Budget Utilization by User",
            "type": "bargauge",
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "targets": [
                {
                    "expr": "llm_router_budget_usage_percent",
                    "legendFormat": "{{user}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 70 },
                            { "color": "orange", "value": 85 },
                            { "color": "red", "value": 95 }
                        ]
                    }
                }
            },
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 }
        },
        {
            "title": "🔐 Security & Rate Limiting",
            "type": "row",
            "collapsed": true,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
            "panels": [
                {
                    "title": "Authentication Failures",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "sum(rate(llm_router_security_auth_failures_total{job=\"llm-router\"}[5m])) by (type)",
                            "legendFormat": "{{type}}"
                        }
                    ],
                    "fieldConfig": {
                        "defaults": {
                            "custom": { "fillOpacity": 30 },
                            "color": { "mode": "palette-classic" }
                        }
                    },
                    "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 }
                },
                {
                    "title": "Rate Limit Rejections",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "sum(rate(llm_router_security_ratelimit_exceeded_total{job=\"llm-router\"}[5m])) by (identifier)",
                            "legendFormat": "{{identifier}}"
                        }
                    ],
                    "fieldConfig": {
                        "defaults": {
                            "custom": { "fillOpacity": 20, "drawStyle": "bars" }
                        }
                    },
                    "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 }
                },
                {
                    "title": "Quota Exceeded Events",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "sum(rate(llm_router_security_quota_exceeded_total{job=\"llm-router\"}[5m])) by (type)",
                            "legendFormat": "{{type}}"
                        }
                    ],
                    "fieldConfig": {
                        "defaults": {
                            "custom": { "fillOpacity": 20 }
                        }
                    },
                    "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 }
                }
            ]
        },
        {
            "title": "🖥️ Infrastructure",
            "type": "row",
            "collapsed": true,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
            "panels": [
                {
                    "title": "PostgreSQL Connections",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "go_sql_open_connections{job=\"llm-router\"}",
                            "legendFormat": "Open"
                        },
                        {
                            "expr": "go_sql_idle_connections{job=\"llm-router\"}",
                            "legendFormat": "Idle"
                        }
                    ],
                    "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 }
                },
                {
                    "title": "Goroutines",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "go_goroutines{job=\"llm-router\"}",
                            "legendFormat": "Goroutines"
                        }
                    ],
                    "fieldConfig": {
                        "defaults": {
                            "custom": { "fillOpacity": 10 },
                            "thresholds": {
                                "mode": "absolute",
                                "steps": [
                                    { "color": "green", "value": null },
                                    { "color": "yellow", "value": 500 },
                                    { "color": "red", "value": 1000 }
                                ]
                            }
                        }
                    },
                    "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 }
                },
                {
                    "title": "Heap Memory",
                    "type": "timeseries",
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "targets": [
                        {
                            "expr": "go_memstats_heap_alloc_bytes{job=\"llm-router\"}",
                            "legendFormat": "Heap Alloc"
                        },
                        {
                            "expr": "go_memstats_heap_inuse_bytes{job=\"llm-router\"}",
                            "legendFormat": "Heap In-Use"
                        }
                    ],
                    "fieldConfig": {
                        "defaults": {
                            "unit": "decbytes",
                            "custom": { "fillOpacity": 10 }
                        }
                    },
                    "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 }
                }
            ]
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "llm-router",
        "api-gateway",
        "observability"
    ],
    "templating": {
        "list": [
            {
                "name": "DS_PROMETHEUS",
                "type": "datasource",
                "query": "prometheus"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "title": "LLM Router Platform",
    "uid": "llm-router-overview"
}