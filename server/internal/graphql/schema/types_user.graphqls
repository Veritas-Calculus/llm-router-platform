# ──────────────────────────────────────────────────
# User types
# ──────────────────────────────────────────────────

type User {
  id: ID!
  email: String!
  name: String!
  role: String!
  isActive: Boolean!
  requirePasswordChange: Boolean!
  monthlyTokenLimit: Int
  monthlyBudgetUsd: Float
  balance: Float
  createdAt: DateTime!
  lastLoginAt: DateTime
  mfaEnabled: Boolean!
}

type MfaSecretInfo {
  secret: String!
  qrCodeUrl: String!
  backupCodes: [String!]!
}

type Organization {
  id: ID!
  name: String!
  billingLimit: Float!
  createdAt: DateTime!
}

type OrganizationMember {
  userId: ID!
  orgId: ID!
  role: String!
  user: UserListItem!
  createdAt: DateTime!
}

type Project {
  id: ID!
  orgId: ID!
  name: String!
  description: String
  quotaLimit: Float!
  whiteListedIps: String
  createdAt: DateTime!
}

input UpdateProjectInput {
  name: String
  description: String
  quotaLimit: Float
  whiteListedIps: String
}

type ApiKey {
  id: ID!
  projectId: ID!
  channel: String!
  name: String!
  keyPrefix: String!
  isActive: Boolean!
  scopes: String!
  rateLimit: Int!
  tokenLimit: Int!
  dailyLimit: Int!
  expiresAt: DateTime
  lastUsedAt: DateTime
  createdAt: DateTime!
}

type ApiKeyWithSecret {
  id: ID!
  projectId: ID!
  channel: String!
  name: String!
  key: String!
  keyPrefix: String!
  isActive: Boolean!
  scopes: String!
  rateLimit: Int!
  tokenLimit: Int!
  dailyLimit: Int!
  expiresAt: DateTime
  createdAt: DateTime!
}

type UserConnection {
  data: [UserListItem!]!
  total: Int!
}

type UserListItem {
  id: ID!
  email: String!
  name: String!
  role: String!
  isActive: Boolean!
  lastLoginAt: DateTime
  createdAt: DateTime!
  apiKeyCount: Int!
}

type UserDetail {
  id: ID!
  email: String!
  name: String!
  role: String!
  isActive: Boolean!
  createdAt: DateTime!
  apiKeys: Int!
  monthlyTokenLimit: Int
  monthlyBudgetUsd: Float
  mfaEnabled: Boolean!
  usageMonth: UserMonthlyUsage
}

type UserMonthlyUsage {
  totalRequests: Int!
  totalTokens: Int!
  totalCost: Float!
  avgLatency: Float!
  successRate: Float!
  errorCount: Int!
}

input QuotaInput {
  monthlyTokenLimit: Int
  monthlyBudgetUsd: Float
}
