type ErrorLog {
  id: ID!
  trajectoryId: String!
  traceId: String!
  provider: String!
  model: String!
  statusCode: Int!
  headers: String!
  responseBody: String!
  createdAt: DateTime!
}

type ErrorLogConnection {
  data: [ErrorLog!]!
  total: Int!
  page: Int!
  pageSize: Int!
}

type LogEntry {
  timestamp: String!
  level: String!
  message: String!
  requestId: String
  caller: String
  error: String
  method: String
  path: String
  statusCode: Int
  latency: Float
  clientIp: String
  userAgent: String
  rawJson: String
}
